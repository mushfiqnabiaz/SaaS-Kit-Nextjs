# ============================================================
# Next.js SaaS Boilerplate — .gitignore
# ============================================================

# ----- Dependencies -----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ----- Next.js -----
.next/
out/
build/
dist/

# ----- Environment variables -----
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# Keep the example file — it's safe to commit
!.env.local.example
!.env.example

# ----- Database -----
# Drizzle migrations output (keep the folder, ignore generated sql if desired)
# drizzle/*.sql
.drizzle/

# SQLite (if used locally for testing)
*.sqlite
*.sqlite3
*.db

# MongoDB local data
data/db/

# ----- Auth -----
# Auth.js / NextAuth generated files
.auth/

# ----- Uploads & media -----
public/uploads/
uploads/

# ----- Testing -----
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
e2e/.auth/

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- OS files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- Editor & IDE -----
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Keep recommended VSCode settings
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- Docker -----
# Ignore local docker volume data
docker/data/
.docker/

# ----- Markdown -----
*.md
# Keep the main README — it's part of the project
!README.md

# ----- Misc -----
.vercel
.turbo
*.pem
.cache/
tmp/
temp/