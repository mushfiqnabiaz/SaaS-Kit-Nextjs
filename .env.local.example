# App branding (shown on auth pages)
NEXT_PUBLIC_APP_NAME=SaaSKit

# Database driver: mongo | postgres
DB_DRIVER=mongo

# MongoDB (when DB_DRIVER=mongo)
MONGODB_URI=mongodb://localhost:27017/saas-boilerplate

# PostgreSQL (when DB_DRIVER=postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/saas_boilerplate

# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — SMTP (recommended for self-hosted / Mailtrap / Gmail app password)
# When SMTP_HOST is set, all transactional email uses SMTP.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com

# Email — Resend (optional fallback if SMTP_HOST is not set)
RESEND_API_KEY=
# EMAIL_FROM is used as the From address for both SMTP and Resend

# Require verified email before login (credentials users)
REQUIRE_EMAIL_VERIFICATION=false

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Registration: set to "true" to allow sign-up without invite or company name
ALLOW_PUBLIC_SIGNUP=false

# Seed script — run: npm run seed
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=change-me-secure-password
SEED_DEMO_PASSWORD=demo-password-change-me
